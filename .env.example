# ===== Database (Neon PostgreSQL) =====
# Ambil dari https://neon.tech -> Project -> Connection string (pooled)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Connection langsung (non-pooled) untuk migrasi Prisma
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ===== Auth.js (NextAuth v5) =====
# Generate: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-random-string-panjang"
# URL aplikasi (saat lokal biarkan begini)
NEXTAUTH_URL="http://localhost:3000"

# ===== Akun admin awal (dipakai saat seed) =====
ADMIN_EMAIL="admin@marketplace.test"
ADMIN_PASSWORD="admin12345"

# ===== Midtrans (Sandbox) =====
# Ambil dari https://dashboard.sandbox.midtrans.com -> Settings -> Access Keys
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"

# ===== Vercel Blob (penyimpanan file digital) =====
# Ambil dari Vercel -> Storage -> Blob -> Tokens
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ===== URL publik aplikasi (untuk metadata/SEO & link download) =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
